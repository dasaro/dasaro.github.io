{%- comment -%}
  Site-local customization: subtle animated mathematical backgrounds.
  Logic lives in assets/js/math-bg.js. Injected site-wide from the local
  override of _layouts/default.liquid. Keyboard: "b" cycles, 1–5 pick, "0" off.
{%- endcomment -%}
<canvas id="math-bg" aria-hidden="true"
        style="position:fixed; inset:0; width:100vw; height:100vh; z-index:-1; pointer-events:none; opacity:0; transform:translateZ(0); backface-visibility:hidden; will-change:opacity;"></canvas>
<span id="math-bg-probe" aria-hidden="true"
      style="position:fixed; left:0; top:0; visibility:hidden; color:var(--global-text-color-light);">.</span>
<div id="math-bg-note" role="button" tabindex="0" aria-live="polite" title="Tap (or press b) to change the background"
     style="position:fixed; left:.7rem; bottom:.6rem; z-index:1031; max-width:min(32rem,90vw); font-size:.72rem; line-height:1.45; color:var(--global-text-color-light); opacity:0; transition:opacity .45s ease; pointer-events:auto; cursor:pointer; background:color-mix(in srgb, var(--global-bg-color, Canvas) 88%, transparent); -webkit-backdrop-filter:blur(3px); backdrop-filter:blur(3px); padding:.35rem .65rem; border:1px solid var(--global-divider-color); border-radius:.5rem;"></div>
<script defer src="{{ '/assets/js/math-bg.js' | relative_url | bust_file_cache }}"></script>
