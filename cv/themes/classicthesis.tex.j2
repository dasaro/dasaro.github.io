\VAR{data.languages | map("tex") | join("  \\textbullet\\  ")}
%% endif

%% if sec == "interests" and data.interests
\CVsec{Interests}
\VAR{data.interests | map("tex") | join("  \\textbullet\\  ")}
%% endif

%% endfor

\end{document}
