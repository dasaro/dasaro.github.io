%% if sec == "groups" and data.groups
\CVsec{Research Groups}
\begin{itemize}
%% for g in data.groups
\item \BLOCK{if g.url}\href{\VAR{g.url}}{\VAR{g.name | tex}}\BLOCK{else}\VAR{g.name | tex}\BLOCK{endif}
%% endfor
\end{itemize}
%% endif

%% if sec == "memberships" and data.memberships
\CVsec{Memberships}
\begin{itemize}
%% for m in data.memberships
