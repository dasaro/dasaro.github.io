%# ====================================================================
%# themes/classicthesis.tex.j2 — faithful to the user's classicthesis/currvita
%# cv_8.tex: flush-left spaced small-caps headings, a 2em body indent for
%# entries/descriptions, sub-lists indented further, red only for the name +
%# links, no greys or rules. Standard LaTeX (Palatino via TeX Gyre Pagella),
%# driven by cv.yml + papers.bib via build_cv.py.
%# ====================================================================
\documentclass[10pt,a4paper]{article}

\usepackage[T1]{fontenc}
\usepackage[utf8]{inputenc}
\ifdefined\pdftrailerid\pdftrailerid{dasaro-cv}\fi % fixed PDF /ID -> byte-reproducible builds
\usepackage{tgpagella}             % TeX Gyre Pagella: Palatino clone with real small caps (vector Type 1)
\linespread{1.04}
\usepackage[left=3.5cm,right=3.5cm,top=2.8cm,bottom=2.5cm]{geometry} % wide symmetric margins, matched to New_CV.pdf
\usepackage{microtype}             % protrusion + \textls letterspacing
\usepackage{enumitem}
\usepackage{xcolor}
\usepackage[hidelinks]{hyperref}

\definecolor{accent}{HTML}{\VAR{accent}}
\definecolor{datemuted}{gray}{0.45}   % muted grey for the date column
\hypersetup{colorlinks=true, urlcolor=accent, linkcolor=accent}

%# --- spaced (all/low) small caps, classicthesis style ---
\newcommand{\spacedcaps}[1]{\textls[110]{\MakeUppercase{#1}}}
\newcommand{\spacedsc}[1]{\textls[70]{\scshape\MakeLowercase{#1}}}

\newlength{\bodyindent}\setlength{\bodyindent}{0.77cm} % date-column indent, matched to New_CV.pdf (~2em)
\newlength{\dbox}\settowidth{\dbox}{2026 -- present}  % width of the date column

%# --- section heading: black spaced small caps, flush-left, no rule ---
\newcommand{\CVsec}[1]{\bigskip\par\noindent{\normalsize\spacedsc{#1}}\par\vspace{0.35em}}

%# --- entry: date column indented by \bodyindent, title to its right ---
%# date sits in a fixed makebox on the first line; the title flows as normal text with a
%# hanging indent so wrapped title lines align under the title AND multi-line titles keep
%# correct spacing to the description below (a \parbox[t] would let line 2 overlap it).
\newcommand{\NewEntry}[2]{\smallskip\par\noindent%
  \hspace*{\bodyindent}\makebox[\dbox][l]{\small\itshape\color{datemuted}#1}\hspace{1em}%
  \hangafter=1\hangindent=\dimexpr\bodyindent+\dbox+1em\relax
  #2\par}

%# --- description: text block indented to \bodyindent (text only -> \leftskip is safe) ---
\newcommand{\Desc}[1]{{\leftskip\bodyindent\relax\noindent\footnotesize #1\par}\vspace{0.35em}}

%# --- publications grouped by year: the year is a single left-margin heading (shown once),
%#     and each paper below it is a clean "title / authors, venue, doi" block. ---
\newlength{\pubindent}\setlength{\pubindent}{2em}
\newcommand{\PubYear}[1]{\smallskip\par\noindent{\itshape\color{datemuted} #1}\par\nobreak\vspace{0.2em}}
\newlist{pubitems}{itemize}{1}
\setlist[pubitems]{label=\textbullet, leftmargin=\dimexpr\pubindent+0.9em\relax,
                   itemsep=0.55em, topsep=0.15em, parsep=0pt}

%# --- bullet list under an entry/heading: indented via enumitem leftmargin (composes cleanly) ---
\setlist[itemize]{label=\textbullet, leftmargin=\dimexpr\bodyindent+1.4em\relax,
                  itemsep=0.12em, topsep=0.2em, parsep=0pt}
\newlist{cvitems}{itemize}{1}
\setlist[cvitems]{label=\textbullet, leftmargin=\dimexpr\bodyindent+1.4em\relax,
                  itemsep=0.12em, topsep=0.15em, parsep=0pt}

\setlength{\parindent}{0pt}
\pagestyle{empty}

\begin{document}

%# ======================= HEADER =======================
{\LARGE\color{accent}\spacedcaps{\VAR{basics.name}}}\par\vspace{0.4em}
{\itshape \VAR{basics.headline | tex}}\par\vspace{0.5em}
{\small
  \href{mailto:\VAR{basics.email}}{\VAR{basics.email}}%
  \BLOCK{if basics.phone}\ \textbar\ \VAR{basics.phone | tex}\BLOCK{endif}%
  \BLOCK{if basics.website}\ \textbar\ \href{\VAR{basics.website}}{website}\BLOCK{endif}%
  \BLOCK{if basics.scholar}\ \textbar\ \href{\VAR{basics.scholar}}{Scholar}\BLOCK{endif}%
  \BLOCK{if basics.github}\ \textbar\ \href{\VAR{basics.github}}{GitHub}\BLOCK{endif}%
}\par\vspace{0.6em}
\BLOCK{if basics.summary}
{\small \VAR{basics.summary | tex}}\par
\BLOCK{endif}

