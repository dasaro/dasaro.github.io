{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "_data/films.yml — grid on /films/",
  "description": "Favourite films shown on the /films/ page.",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["title", "url"],
    "properties": {
      "title": { "type": "string", "description": "Original title." },
      "director": { "type": "string" },
      "year": { "type": "integer" },
      "note": { "type": "string", "description": "Optional English title or short remark." },
      "url": { "type": "string", "description": "Rotten Tomatoes page (https://www.rottentomatoes.com/m/...)." }
    }
  }
}
